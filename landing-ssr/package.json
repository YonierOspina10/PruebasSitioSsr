{
  "name": "landing-ssr",
  "main": "dist/spa/landing-ssr.es.js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:worker": "wrangler dev",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:ssr": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:spa": "vite build --config vite.config.spa.ts",
    "build:node": "tsc -p tsconfig.server.json",
    "build": "vue-tsc -b && npm run build:client && npm run build:ssr && npm run build:node",
    "build:worker": "vue-tsc -b && npm run build:client && npm run build:ssr",
    "deploy": "npm run build:worker && wrangler deploy",
    "start": "node dist/server.js",
    "preview": "node dist/server.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "pinia": "^3.0.4",
    "single-spa": "^6.0.1",
    "single-spa-vue": "^3.0.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/server-renderer": "^3.5.30",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.19",
    "daisyui": "^2.51.5",
    "postcss": "^8.4.38",
    "tailwindcss": "3.1.8",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5",
    "@cloudflare/workers-types": "^4.20250109.0",
    "wrangler": "^4.0.0"
  }
}
